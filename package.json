{
  "name": "bsl-format-string-wizard",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "icon": "images/bsl-format-string-wizard-icon.png",
  "publisher": "sh17ck",
  "license": "MIT",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/sh17ck/bsl-format-string-wizard.git"
  },
  "bugs": {
    "url": "https://github.com/sh17ck/bsl-format-string-wizard/issues"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "bsl-format-string-wizard.useRussianTerms": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.useRussianTerms.description%"
        }
      }
    },
    "commands": [
      {
        "command": "bsl-format-string-wizard.quickPickFormatString",
        "title": "%command.quickPickFormatString.title%",
        "category": "%category.bslFormatStringWizard%"
      },
      {
        "command": "bsl-format-string-wizard.handleCtrlEnter",
        "title": "%command.handleCtrlEnter.title%",
        "category": "%category.bslFormatStringWizard%"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "bsl-format-string-wizard.quickPickFormatString",
          "when": "editorLangId == 'bsl' || resourceExtname == '.bsl' || resourceExtname == '.os'"
        },
        {
          "command": "bsl-format-string-wizard.handleCtrlEnter",
          "when": "false"
        }
      ],
      "editor/context": [
        {
          "command": "bsl-format-string-wizard.quickPickFormatString",
          "when": "editorLangId == 'bsl' || resourceExtname == '.bsl' || resourceExtname == '.os'",
          "group": "bslFormatStringWizard"
        }
      ]
    },
    "keybindings": [
      {
        "command": "bsl-format-string-wizard.handleCtrlEnter",
        "key": "ctrl+enter",
        "when": "inQuickOpen && isMyQuickPickActive"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
